# Core
SKILLANYTHING_HOME=./data
SKILLANYTHING_RSSHUB_BASE=https://rsshub.app

# Cloud model path. If omitted, distillation falls back to deterministic local heuristics.
OPENAI_API_KEY=
SKILLANYTHING_MODEL=

# OpenAI-compatible text model for final research distillation. Defaults to the DashScope
# vision credentials below when omitted.
SKILLANYTHING_LLM_BASE_URL=
SKILLANYTHING_LLM_API_KEY=
SKILLANYTHING_LLM_MODEL=qwen3-vl-plus

# X official API path.
X_BEARER_TOKEN=

# Optional browser capture.
SKILLANYTHING_CDP_URL=http://127.0.0.1:9222

# Xueqiu text collection. Without this cookie, SkillAnything can usually read the first
# public timeline page only; configure your own logged-in Cookie to fetch more pages.
SKILLANYTHING_XUEQIU_COOKIE=

# 国内多模态服务建议使用兼容 OpenAI chat/completions 的视觉模型网关：
# DashScope 百炼 / SiliconFlow / 火山方舟等都可通过下列变量接入。
SKILLANYTHING_VISION_BASE_URL=
SKILLANYTHING_VISION_API_KEY=
SKILLANYTHING_VISION_MODEL=qwen-vl-max

# ASR 可以接入任意 HTTP 转写服务，服务返回 JSON 里的 text/transcript/result.text。
SKILLANYTHING_ASR_BASE_URL=
SKILLANYTHING_ASR_API_KEY=
SKILLANYTHING_ASR_MODEL=qwen3-asr-flash
SKILLANYTHING_ASR_LANGUAGE=zh
SKILLANYTHING_MEDIA_MAX_ASSETS=80
